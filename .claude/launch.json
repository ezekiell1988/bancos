{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": [
        "watch",
        "--project",
        "src/Bancos.Api/Bancos.Api.csproj",
        "--urls",
        "http://localhost:8000"
      ],
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "bancos-mcp",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": [
        "watch",
        "--project",
        "src/Bancos.Mcp/Bancos.Mcp.csproj",
        "--urls",
        "http://localhost:8000"
      ],
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd src/Bancos.Web && npx ng serve --port 4200 --ssl"
      ],
      "port": 4200,
      "autoPort": false,
      "url": "https://localhost:4200/",
      "readyPattern": "Local:"
    }
  ]
}
