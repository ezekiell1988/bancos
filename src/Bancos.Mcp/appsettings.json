{
  "Mcp": {
    "ServerName": "bancos-mcp",
    "ServerVersion": "1.0.0",
    "AllowedOrigins": ["https://chatgpt.com"]
  },
  "FileTemplateDetection": {
    "InputDirectory": "../input",
