{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "bancos-web": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "public" }],
            "styles": ["src/styles.css"],
            "outputPath": "dist/bancos-web"
          },
          "configurations": { "production": { "optimization": true, "outputHashing": "all" } }
        },
        "serve": { "builder": "@angular/build:dev-server", "configurations": { "production": { "buildTarget": "bancos-web:build:production" }, "development": { "buildTarget": "bancos-web:build" } }, "defaultConfiguration": "development" }
      }
    }
  }
}
